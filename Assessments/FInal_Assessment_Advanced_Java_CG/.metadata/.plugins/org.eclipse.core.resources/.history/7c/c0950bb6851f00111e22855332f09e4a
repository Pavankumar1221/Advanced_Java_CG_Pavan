server:
  port: 6606

spring:
  application:
    name: car-rental-service

  config:
    import: "configserver:http://localhost:6600"

  cloud:
    config:
      fail-fast: true

management:
  endpoints:
    web:
      exposure:
        include: "*"

eureka:
  client:
    service-url:
      defaultZone: http://localhost:6601/eureka

  instance:
    prefer-ip-address: true